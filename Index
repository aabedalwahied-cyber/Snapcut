<!DOCTYPE html>

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SnapCut — وثيقة المشروع الشاملة</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0A0A0A;
  --white: #FFFFFF;
  --cream: #F8F5F0;
  --gold: #C8952A;
  --gold2: #E8B84B;
  --green: #166640;
  --green2: #1D8A55;
  --red: #8C1F1F;
  --blue: #0F3460;
  --purple: #3A0F6E;
  --border: rgba(200,149,42,0.25);
  --muted: #888;
  --card-bg: #111111;
  --section-bg: #0F0F0F;
}

- { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }

body {
font-family: ‘Cairo’, sans-serif;
background: var(–black);
color: var(–white);
line-height: 1.8;
overflow-x: hidden;
}

/* ════════════════════════════════════
COVER
════════════════════════════════════ */
.cover {
min-height: 100vh;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
text-align: center;
padding: 80px 40px;
position: relative;
background: var(–black);
overflow: hidden;
}

.cover-noise {
position: absolute; inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.04’/%3E%3C/svg%3E”);
opacity: 0.4;
}

.cover-glow {
position: absolute;
width: 700px; height: 700px;
border-radius: 50%;
background: radial-gradient(circle, rgba(200,149,42,0.08) 0%, transparent 70%);
top: 50%; left: 50%;
transform: translate(-50%, -50%);
}

.cover-lines {
position: absolute; inset: 0;
background-image: repeating-linear-gradient(
0deg,
transparent,
transparent 79px,
rgba(200,149,42,0.04) 79px,
rgba(200,149,42,0.04) 80px
),
repeating-linear-gradient(
90deg,
transparent,
transparent 79px,
rgba(200,149,42,0.04) 79px,
rgba(200,149,42,0.04) 80px
);
}

.cover-content { position: relative; z-index: 2; max-width: 900px; }

.cover-eyebrow {
font-size: 10px;
letter-spacing: 6px;
color: var(–gold);
font-weight: 700;
margin-bottom: 50px;
font-family: ‘Tajawal’, sans-serif;
opacity: 0.8;
}

.app-names-row {
display: flex;
gap: 16px;
justify-content: center;
flex-wrap: wrap;
margin-bottom: 16px;
}

.app-name-btn {
font-family: ‘Tajawal’, sans-serif;
font-weight: 900;
font-size: clamp(38px, 6vw, 76px);
color: rgba(255,255,255,0.12);
cursor: pointer;
transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
letter-spacing: -2px;
line-height: 1;
padding: 4px 12px;
border: 1px solid transparent;
background: none;
user-select: none;
}

.app-name-btn.active {
color: var(–gold2);
border-color: rgba(200,149,42,0.3);
text-shadow: 0 0 80px rgba(200,149,42,0.5);
background: rgba(200,149,42,0.05);
}

.app-name-btn:hover:not(.active) { color: rgba(255,255,255,0.35); }

.name-hint {
font-size: 12px;
color: rgba(255,255,255,0.25);
letter-spacing: 2px;
margin-bottom: 48px;
font-family: ‘Tajawal’, sans-serif;
}

.cover-tagline {
font-family: ‘Tajawal’, sans-serif;
font-size: clamp(16px, 2.5vw, 22px);
font-weight: 300;
color: rgba(255,255,255,0.6);
max-width: 640px;
margin: 0 auto 60px;
line-height: 2;
}

.cover-tagline strong {
color: rgba(255,255,255,0.9);
font-weight: 600;
}

.cover-metrics {
display: flex;
justify-content: center;
gap: 0;
border: 1px solid var(–border);
max-width: 600px;
margin: 0 auto 60px;
}

.cover-metric {
flex: 1;
padding: 24px 20px;
border-left: 1px solid var(–border);
text-align: center;
}
.cover-metric:last-child { border-left: none; }

.metric-val {
font-family: ‘Tajawal’, sans-serif;
font-size: 28px;
font-weight: 800;
color: var(–gold2);
display: block;
line-height: 1;
margin-bottom: 6px;
}
.metric-lbl {
font-size: 10px;
letter-spacing: 2px;
color: rgba(255,255,255,0.35);
font-family: ‘Tajawal’, sans-serif;
}

.scroll-hint {
font-size: 11px;
letter-spacing: 3px;
color: rgba(255,255,255,0.2);
animation: pulse 2s infinite;
}

@keyframes pulse { 0%,100%{opacity:0.2} 50%{opacity:0.6} }

/* ════════════════════════════════════
NAV
════════════════════════════════════ */
nav {
position: sticky; top: 0; z-index: 100;
background: rgba(10,10,10,0.96);
backdrop-filter: blur(20px);
border-bottom: 1px solid var(–border);
padding: 0 40px;
overflow-x: auto;
}

.nav-inner {
display: flex;
max-width: 1100px;
margin: 0 auto;
white-space: nowrap;
}

nav a {
display: inline-block;
padding: 18px 18px;
font-size: 12px;
letter-spacing: 1px;
font-weight: 700;
color: rgba(255,255,255,0.35);
text-decoration: none;
border-bottom: 2px solid transparent;
transition: all 0.2s;
font-family: ‘Tajawal’, sans-serif;
}
nav a:hover { color: rgba(255,255,255,0.7); }
nav a.active { color: var(–gold2); border-bottom-color: var(–gold); }

/* ════════════════════════════════════
LAYOUT
════════════════════════════════════ */
.container { max-width: 1100px; margin: 0 auto; padding: 0 40px; }

.section {
padding: 100px 0;
border-bottom: 1px solid rgba(255,255,255,0.05);
}

.section-eyebrow {
font-size: 10px;
letter-spacing: 5px;
color: var(–gold);
font-weight: 700;
font-family: ‘Tajawal’, sans-serif;
margin-bottom: 16px;
display: block;
}

.section-title {
font-family: ‘Tajawal’, sans-serif;
font-size: clamp(32px, 4vw, 52px);
font-weight: 900;
line-height: 1.1;
margin-bottom: 20px;
letter-spacing: -1px;
}

.section-desc {
font-size: 16px;
color: rgba(255,255,255,0.45);
max-width: 580px;
font-weight: 300;
line-height: 1.9;
}

/* ════════════════════════════════════
PROBLEM / OPPORTUNITY
════════════════════════════════════ */
.prob-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 2px;
margin-top: 60px;
background: var(–border);
border: 1px solid var(–border);
}

.prob-card {
background: var(–card-bg);
padding: 40px 36px;
}

.prob-card.highlight {
background: linear-gradient(135deg, rgba(200,149,42,0.12), rgba(200,149,42,0.04));
border: 1px solid rgba(200,149,42,0.2);
}

.prob-label {
font-size: 10px; letter-spacing: 3px; font-weight: 700;
color: var(–gold); margin-bottom: 16px; display: block;
font-family: ‘Tajawal’, sans-serif;
}

.prob-title {
font-family: ‘Tajawal’, sans-serif;
font-size: 22px; font-weight: 800; margin-bottom: 16px;
line-height: 1.3; color: var(–white);
}

.prob-body {
font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.9; font-weight: 300;
}

.prob-stat {
font-family: ‘Tajawal’, sans-serif;
font-size: 48px; font-weight: 900; color: var(–gold2);
margin-top: 24px; display: block; line-height: 1;
}

.prob-stat-label {
font-size: 13px; color: rgba(255,255,255,0.35); margin-top: 8px; display: block;
}

/* ════════════════════════════════════
COMPETITORS
════════════════════════════════════ */
.comp-table {
width: 100%; border-collapse: collapse; margin-top: 50px;
font-size: 14px;
}

.comp-table th {
padding: 16px 20px; text-align: right;
font-size: 10px; letter-spacing: 3px; font-weight: 700;
color: var(–gold); background: var(–card-bg);
border-bottom: 1px solid var(–border);
font-family: ‘Tajawal’, sans-serif;
}

.comp-table td {
padding: 18px 20px; border-bottom: 1px solid rgba(255,255,255,0.06);
color: rgba(255,255,255,0.7); vertical-align: top;
background: rgba(255,255,255,0.02);
}

.comp-table tr:last-child td { border-bottom: none; }

.comp-table .our-row td {
background: linear-gradient(90deg, rgba(200,149,42,0.08), rgba(200,149,42,0.03));
color: var(–white);
font-weight: 600;
}

.comp-table .our-row td:first-child {
border-right: 3px solid var(–gold);
}

.check { color: #4CAF50; font-size: 16px; }
.cross { color: #f44336; font-size: 16px; }
.partial { color: var(–gold2); font-size: 16px; }

/* ════════════════════════════════════
MARKET
════════════════════════════════════ */
.market-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 2px;
background: var(–border);
border: 1px solid var(–border);
margin-top: 60px;
}

.market-card {
background: var(–card-bg);
padding: 36px 28px;
text-align: center;
}

.market-num {
font-family: ‘Tajawal’, sans-serif;
font-size: 42px; font-weight: 900;
color: var(–gold2); line-height: 1;
margin-bottom: 10px; display: block;
}

.market-lbl {
font-size: 12px; color: rgba(255,255,255,0.4);
line-height: 1.6; font-weight: 300;
}

/* ════════════════════════════════════
REVENUE MODEL
════════════════════════════════════ */
.rev-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 30px;
margin-top: 60px;
}

.rev-card {
border: 1px solid var(–border);
padding: 36px;
background: var(–card-bg);
position: relative;
overflow: hidden;
}

.rev-card::before {
content: ‘’;
position: absolute; top: 0; right: 0;
width: 3px; height: 100%;
background: var(–gold);
}

.rev-card-title {
font-family: ‘Tajawal’, sans-serif;
font-size: 20px; font-weight: 800; margin-bottom: 12px;
}

.rev-card-price {
font-family: ‘Tajawal’, sans-serif;
font-size: 42px; font-weight: 900;
color: var(–gold2); line-height: 1; margin-bottom: 8px;
}

.rev-card-sub { font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 24px; }

.rev-list { list-style: none; }
.rev-list li {
font-size: 14px; color: rgba(255,255,255,0.6);
padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
display: flex; gap: 10px;
}
.rev-list li::before { content: ‘—’; color: var(–gold); flex-shrink: 0; }
.rev-list li:last-child { border-bottom: none; }

/* ════════════════════════════════════
FINANCIAL PROJECTIONS
════════════════════════════════════ */
.proj-table {
width: 100%; border-collapse: collapse;
margin-top: 50px; font-size: 14px;
}

.proj-table th {
padding: 16px 20px; text-align: center;
font-size: 10px; letter-spacing: 3px; font-weight: 700;
color: var(–gold); background: var(–card-bg);
border-bottom: 1px solid var(–border);
font-family: ‘Tajawal’, sans-serif;
}

.proj-table td {
padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,0.06);
text-align: center; color: rgba(255,255,255,0.7);
}

.proj-table .highlight-row td { color: var(–gold2); font-weight: 700; }
.proj-table .total-row td { color: var(–white); font-weight: 800; background: rgba(200,149,42,0.08); font-size: 15px; }

.proj-note {
font-size: 12px; color: rgba(255,255,255,0.3);
margin-top: 16px; font-style: italic; text-align: center;
}

/* ════════════════════════════════════
ECOSYSTEM / APPS
════════════════════════════════════ */
.apps-grid {
display: grid;
grid-template-columns: repeat(5, 1fr);
gap: 2px;
background: var(–border);
border: 1px solid var(–border);
margin-top: 60px;
}

.app-card {
background: var(–card-bg);
padding: 32px 24px;
text-align: center;
position: relative;
overflow: hidden;
}

.app-card::after {
content: ‘’;
position: absolute; bottom: 0; left: 0; right: 0;
height: 2px;
}

.app-card.c1::after { background: #1D8A55; }
.app-card.c2::after { background: #1A5C99; }
.app-card.c3::after { background: #6B2FAB; }
.app-card.c4::after { background: #C8952A; }
.app-card.c5::after { background: #8C3A1A; }

.app-icon { font-size: 36px; margin-bottom: 16px; display: block; }

.app-name2 {
font-family: ‘Tajawal’, sans-serif;
font-size: 15px; font-weight: 800; margin-bottom: 6px;
}

.app-desc { font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.6; margin-bottom: 16px; }

.app-tag2 {
font-size: 10px; letter-spacing: 1px; font-weight: 700;
padding: 4px 10px;
border: 1px solid rgba(255,255,255,0.1);
color: rgba(255,255,255,0.4);
display: inline-block; margin: 2px;
}

/* ════════════════════════════════════
FLOW SECTION
════════════════════════════════════ */
.flow-tabs {
display: flex; gap: 0;
border: 1px solid var(–border);
margin-top: 60px;
overflow-x: auto;
}

.flow-tab {
flex: 1; padding: 18px 20px;
background: var(–card-bg);
border-none; border-left: 1px solid var(–border);
color: rgba(255,255,255,0.35);
cursor: pointer; font-size: 13px; font-weight: 700;
transition: all 0.2s; text-align: center;
font-family: ‘Tajawal’, sans-serif;
white-space: nowrap;
}

.flow-tab:first-child { border-left: none; }
.flow-tab.active { background: rgba(200,149,42,0.12); color: var(–gold2); border-bottom: 2px solid var(–gold); }
.flow-tab:hover:not(.active) { color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.03); }

.flow-panels { border: 1px solid var(–border); border-top: none; }

.flow-panel { display: none; padding: 48px 40px; }
.flow-panel.active { display: block; }

.flow-steps-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 20px;
}

.flow-step-card {
border: 1px solid rgba(255,255,255,0.07);
padding: 24px;
background: rgba(255,255,255,0.02);
position: relative;
}

.flow-step-num {
position: absolute; top: 20px; left: 20px;
font-family: ‘Tajawal’, sans-serif;
font-size: 10px; letter-spacing: 2px; font-weight: 700;
color: var(–gold); opacity: 0.7;
}

.flow-step-title {
font-family: ‘Tajawal’, sans-serif;
font-size: 16px; font-weight: 800;
margin-bottom: 12px; padding-left: 48px;
}

.flow-step-body { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.9; }

.flow-path-block {
background: rgba(0,0,0,0.4);
border-right: 2px solid var(–gold);
padding: 16px 20px; margin-top: 12px;
font-family: ‘Courier New’, monospace;
font-size: 12px; color: rgba(255,255,255,0.6);
line-height: 2; direction: ltr; text-align: left;
}

.flow-path-block .arr { color: var(–gold2); }

.fl { list-style: none; padding: 0; }
.fl li {
font-size: 13px; padding: 6px 0;
border-bottom: 1px solid rgba(255,255,255,0.05);
color: rgba(255,255,255,0.6);
display: flex; gap: 8px; align-items: flex-start;
}
.fl li:last-child { border-bottom: none; }
.fl li::before { content: ‘—’; color: var(–gold); flex-shrink: 0; margin-top: 2px; }

.note-box {
background: rgba(200,149,42,0.08);
border-right: 2px solid var(–gold);
padding: 14px 18px; margin-top: 16px;
font-size: 13px; color: rgba(255,255,255,0.6);
line-height: 1.8;
}

.tbl { width: 100%; border-collapse: collapse; margin-top: 16px; }
.tbl th { padding: 10px 14px; background: rgba(200,149,42,0.12); color: var(–gold); font-size: 11px; letter-spacing: 2px; text-align: right; }
.tbl td { padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 13px; color: rgba(255,255,255,0.6); }
.tbl tr:last-child td { border-bottom: none; }

/* ════════════════════════════════════
ROADMAP
════════════════════════════════════ */
.roadmap {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 2px;
background: var(–border);
border: 1px solid var(–border);
margin-top: 60px;
}

.road-card {
background: var(–card-bg);
padding: 40px 32px;
position: relative;
overflow: hidden;
}

.road-card.phase1 { background: linear-gradient(160deg, rgba(200,149,42,0.1), var(–card-bg)); }
.road-card.phase2 { background: linear-gradient(160deg, rgba(22,102,64,0.08), var(–card-bg)); }
.road-card.phase3 { background: linear-gradient(160deg, rgba(58,15,110,0.1), var(–card-bg)); }

.road-phase {
font-size: 10px; letter-spacing: 4px; font-weight: 700;
font-family: ‘Tajawal’, sans-serif; margin-bottom: 8px;
}
.phase1 .road-phase { color: var(–gold); }
.phase2 .road-phase { color: var(–green2); }
.phase3 .road-phase { color: #9B59B6; }

.road-title {
font-family: ‘Tajawal’, sans-serif;
font-size: 22px; font-weight: 900; margin-bottom: 6px;
}

.road-time {
font-size: 13px; color: rgba(255,255,255,0.3);
margin-bottom: 28px; font-weight: 300;
}

.road-items { list-style: none; }
.road-items li {
font-size: 13px; padding: 9px 0;
border-bottom: 1px solid rgba(255,255,255,0.06);
color: rgba(255,255,255,0.6); display: flex; gap: 10px;
align-items: flex-start;
}
.road-items li:last-child { border-bottom: none; }
.road-items li::before { content: ‘◆’; font-size: 8px; color: var(–gold); flex-shrink: 0; margin-top: 5px; }

.road-goal {
margin-top: 28px; padding: 16px;
background: rgba(255,255,255,0.04);
font-size: 13px; border-right: 2px solid var(–gold);
}

.road-goal strong { color: var(–gold2); }

/* ════════════════════════════════════
TEAM / STRUCTURE
════════════════════════════════════ */
.structure-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 20px;
margin-top: 60px;
}

.struct-card {
border: 1px solid var(–border);
padding: 32px 28px;
background: var(–card-bg);
}

.struct-icon { font-size: 32px; margin-bottom: 16px; display: block; }
.struct-title { font-family: ‘Tajawal’, sans-serif; font-size: 18px; font-weight: 800; margin-bottom: 12px; }
.struct-body { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.9; }

/* ════════════════════════════════════
FOOTER
════════════════════════════════════ */
footer {
padding: 80px 40px;
text-align: center;
border-top: 1px solid var(–border);
background: var(–black);
}

.footer-logo {
font-family: ‘Tajawal’, sans-serif;
font-size: 48px; font-weight: 900;
color: rgba(255,255,255,0.08);
letter-spacing: -2px;
margin-bottom: 24px; display: block;
}

.footer-note {
font-size: 12px; color: rgba(255,255,255,0.2);
letter-spacing: 2px; font-family: ‘Tajawal’, sans-serif;
}

/* ════════════════════════════════════
FADE IN
════════════════════════════════════ */
.fade { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.fade.in { opacity: 1; transform: translateY(0); }

/* ════════════════════════════════════
RESPONSIVE
════════════════════════════════════ */
@media (max-width: 768px) {
.prob-grid, .rev-grid, .flow-steps-grid, .roadmap, .structure-grid { grid-template-columns: 1fr; }
.apps-grid { grid-template-columns: repeat(2, 1fr); }
.market-grid { grid-template-columns: repeat(2, 1fr); }
.container { padding: 0 20px; }
.cover { padding: 60px 20px; }
.flow-panel { padding: 24px 20px; }
}
</style>

</head>
